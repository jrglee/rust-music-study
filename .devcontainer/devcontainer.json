{
  "name": "rust-music-study",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "extensions": [
    "rust-lang.rust-analyzer",
    "dependi",
    "GitHub.copilot"
  ],
  "postCreateCommand": "rustup component add rustfmt clippy && cargo build",
  "remoteUser": "vscode"
}
